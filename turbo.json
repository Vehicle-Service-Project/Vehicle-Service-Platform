{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["db:generate"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["db:generate"]
    },
    "lint:ci": {
      "dependsOn": ["db:generate"]
    },
    "test": {
      "dependsOn": ["db:generate"]
    },
    "db:generate": {
      "cache": false
    }
  }
}
