{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["db:generate"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["db:generate"]
    },
    "lint:ci": {
      "dependsOn": ["db:generate"],
      "inputs": [
        "src/**",
        "test/**",
        "eslint.config.mjs",
        "tsconfig.json",
        "tsconfig.build.json"
      ]
    },
    "test": {
      "dependsOn": ["db:generate"]
    },
    "db:generate": {
      "inputs": ["prisma/**", "prisma.config.ts"],
      "outputs": ["generated/**"]
    }
  }
}
