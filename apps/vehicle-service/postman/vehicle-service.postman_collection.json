{
  "info": {
    "_postman_id": "vsp-vehicle-service",
    "name": "Vehicle Service",
    "description": "Vehicle Service Platform — vehicle-service API.\n\nBase URL defaults to http://localhost:4203.\n\nUse `userId` from user-service when creating vehicles. The collection stores `vehicleId` after Create vehicle.\n\nImport `local.postman_environment.json` and select the **Local** environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4203"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "vehicleId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Live",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health/live"
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health/ready"
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "List vehicles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vehicles",
              "host": ["{{baseUrl}}"],
              "path": ["vehicles"],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "List vehicles by userId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vehicles?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["vehicles"],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get vehicle by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/vehicles/{{vehicleId}}"
          }
        },
        {
          "name": "Create vehicle",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('vehicleId', String(body.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"make\": \"Toyota\",\n  \"model\": \"Camry\",\n  \"year\": 2022\n}"
            },
            "url": "{{baseUrl}}/vehicles"
          }
        },
        {
          "name": "Update vehicle",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Honda\",\n  \"model\": \"Accord\",\n  \"year\": 2023\n}"
            },
            "url": "{{baseUrl}}/vehicles/{{vehicleId}}"
          }
        },
        {
          "name": "Delete vehicle",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/vehicles/{{vehicleId}}"
          }
        }
      ]
    }
  ]
}
